{
  "name": "@crm/api",
  "version": "0.1.0",
  "private": true,
  "description": "CRM REST API — Bun + Hono + TypeScript (ver app/api/.claude/adr)",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "arch": "depcruise src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/shared/db/seed/index.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.10.16",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.19",
    "postgres": "^3.4.9",
    "qs": "^6.15.2",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/qs": "^6.15.1",
    "dependency-cruiser": "^17.4.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
