{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Contact UUID",
      "example": "01938b0c-..."
    },
    "name": { "type": "string", "example": "Jane Doe" },
    "contactType": {
      "type": "string",
      "enum": ["Person", "Company"],
      "example": "Person"
    },
    "sex": {
      "type": "string",
      "nullable": true,
      "enum": ["Male", "Female", "Other", "Unspecified", null],
      "example": "Female"
    },
    "addressStreet": {
      "type": "string",
      "nullable": true,
      "example": "Av. Corrientes"
    },
    "addressNumber": { "type": "string", "nullable": true, "example": "1234" },
    "addressPostalCode": {
      "type": "string",
      "nullable": true,
      "example": "C1043"
    },
    "addressCity": {
      "type": "string",
      "nullable": true,
      "example": "Buenos Aires"
    },
    "addressProvince": {
      "type": "string",
      "nullable": true,
      "example": "CABA"
    },
    "addressCountry": {
      "type": "string",
      "nullable": true,
      "example": "Argentina"
    },
    "notes": {
      "type": "string",
      "nullable": true,
      "example": "Met at trade show"
    },
    "pipelineState": {
      "type": "string",
      "enum": ["Contact", "Lead", "AtRisk", "Customer", "Discarded"],
      "example": "Contact"
    },
    "sourceChannel": {
      "type": "string",
      "nullable": true,
      "enum": ["Instagram", "WhatsApp", "Referral", "Email", "Other", null],
      "example": "Instagram"
    },
    "interestLevel": {
      "type": "string",
      "nullable": true,
      "enum": ["Cold", "Warm", "Hot", null],
      "example": "Warm"
    },
    "createdBy": {
      "type": "string",
      "description": "User UUID who created this contact"
    },
    "creator": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"],
      "description": "Creator user data. Present on detail endpoint."
    },
    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "channelType": {
            "type": "string",
            "enum": [
              "Phone",
              "Email",
              "WhatsApp",
              "Instagram",
              "Website",
              "Other"
            ]
          },
          "value": { "type": "string" },
          "isPrimary": { "type": "boolean" }
        },
        "required": ["id", "channelType", "value", "isPrimary"]
      },
      "description": "Communication channels"
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    }
  },
  "required": [
    "id",
    "name",
    "contactType",
    "sex",
    "addressStreet",
    "addressNumber",
    "addressPostalCode",
    "addressCity",
    "addressProvince",
    "addressCountry",
    "notes",
    "pipelineState",
    "sourceChannel",
    "interestLevel",
    "createdBy",
    "channels",
    "createdAt",
    "updatedAt"
  ],
  "x-readme-ref-name": "ContactView"
}
