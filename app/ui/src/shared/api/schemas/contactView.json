{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Contact UUID",
      "example": "01938b0c-..."
    },
    "name": { "type": "string", "example": "Jane Doe" },
    "phone": { "type": "string", "nullable": true, "example": "+1234567890" },
    "pipelineState": {
      "type": "string",
      "enum": ["Contact", "Lead", "Customer", "Discarded"],
      "example": "Contact"
    },
    "stateLocked": { "type": "boolean", "example": false },
    "sourceChannel": {
      "type": "string",
      "nullable": true,
      "enum": ["Instagram", "WhatsApp", "Referral", "Email", "Other", null],
      "example": "Instagram"
    },
    "interestLevel": {
      "type": "string",
      "nullable": true,
      "enum": ["Cold", "Warm", "Hot", null],
      "example": "Warm"
    },
    "createdBy": {
      "type": "string",
      "description": "User UUID who created this contact"
    },
    "creator": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"],
      "description": "Creator user data, present only when populated=true"
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    }
  },
  "required": [
    "id",
    "name",
    "phone",
    "pipelineState",
    "stateLocked",
    "sourceChannel",
    "interestLevel",
    "createdBy",
    "createdAt",
    "updatedAt"
  ],
  "x-readme-ref-name": "ContactView"
}
