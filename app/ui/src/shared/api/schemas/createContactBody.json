{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Contact full name",
      "example": "Jane Doe"
    },
    "handle": {
      "type": "string",
      "nullable": true,
      "description": "Social handle or username",
      "example": "@janedoe"
    },
    "phone": {
      "type": "string",
      "nullable": true,
      "description": "Phone number",
      "example": "+1234567890"
    },
    "sourceChannel": {
      "type": "string",
      "nullable": true,
      "enum": ["Instagram", "WhatsApp", "Referral", "Email", "Other", null],
      "description": "Acquisition channel"
    },
    "interestLevel": {
      "type": "string",
      "nullable": true,
      "enum": ["Cold", "Warm", "Hot", null],
      "description": "Interest level"
    }
  },
  "required": ["name"],
  "x-readme-ref-name": "CreateContactBody"
}
