{
  "type": "object",
  "properties": {
    "importId": {
      "type": "string",
      "format": "uuid",
      "description": "Import UUID",
      "example": "01938b0c-0000-7000-0000-000000000001"
    },
    "status": {
      "type": "string",
      "description": "Import lifecycle status",
      "example": "processing"
    },
    "stage": {
      "type": "string",
      "nullable": true,
      "description": "Current processing stage (null until processing begins)",
      "example": "ingesting"
    },
    "totalRows": {
      "type": "integer",
      "nullable": true,
      "description": "Total data rows (null until counting pass completes)",
      "example": 1500
    },
    "processedRows": {
      "type": "integer",
      "description": "Rows committed so far (excludes header)",
      "example": 600
    },
    "okCount": {
      "type": "integer",
      "description": "Rows successfully inserted",
      "example": 580
    },
    "failedCount": {
      "type": "integer",
      "description": "Rows rejected due to validation errors",
      "example": 10
    },
    "duplicatedCount": {
      "type": "integer",
      "description": "Rows skipped as duplicates",
      "example": 10
    },
    "rejectedCsvUrl": {
      "type": "string",
      "nullable": true,
      "format": "uri",
      "description": "Presigned URL for rejected.csv (null when no rejects)",
      "example": "https://storage/imports/..."
    },
    "columnHeaders": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Column headers from the original file",
      "example": ["Full Name", "Email"]
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 creation timestamp",
      "example": "2025-01-01T00:00:00.000Z"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 last-updated timestamp",
      "example": "2025-01-01T00:01:00.000Z"
    }
  },
  "required": [
    "importId",
    "status",
    "stage",
    "totalRows",
    "processedRows",
    "okCount",
    "failedCount",
    "duplicatedCount",
    "rejectedCsvUrl",
    "columnHeaders",
    "createdAt",
    "updatedAt"
  ],
  "x-readme-ref-name": "ImportStatusResponse"
}
