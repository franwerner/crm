{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Project UUID",
      "example": "01938b0c-..."
    },
    "name": { "type": "string", "example": "Website Redesign" },
    "description": {
      "type": "string",
      "nullable": true,
      "example": "Full redesign of the corporate website"
    },
    "contactId": { "type": "string", "description": "Associated contact UUID" },
    "contactName": {
      "type": "string",
      "nullable": true,
      "description": "Associated contact name",
      "example": "Acme Corp"
    },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code",
      "example": "USD"
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Active", "Closed", "Cancelled"],
      "example": "Draft"
    },
    "startDate": {
      "type": "string",
      "description": "Start date (YYYY-MM-DD)",
      "example": "2025-01-01"
    },
    "plannedEndDate": {
      "type": "string",
      "description": "Planned end date (YYYY-MM-DD)",
      "example": "2025-12-31"
    },
    "createdBy": {
      "type": "string",
      "description": "User UUID who created this project"
    },
    "createdByName": {
      "type": "string",
      "nullable": true,
      "description": "Display name of the user who created this project",
      "example": "John Doe"
    },
    "responsiblesCount": {
      "type": "integer",
      "description": "Total number of responsibles",
      "example": 2
    },
    "leads": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "userName": { "type": "string" },
          "role": { "type": "string", "enum": ["Lead", "Member"] }
        },
        "required": ["userId", "userName", "role"]
      },
      "description": "Lead responsibles"
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    }
  },
  "required": [
    "id",
    "name",
    "description",
    "contactId",
    "contactName",
    "currency",
    "status",
    "startDate",
    "plannedEndDate",
    "createdBy",
    "createdByName",
    "responsiblesCount",
    "leads",
    "createdAt",
    "updatedAt"
  ],
  "x-readme-ref-name": "ProjectListItem"
}
