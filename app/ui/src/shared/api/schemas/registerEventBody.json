{
  "type": "object",
  "properties": {
    "eventType": {
      "type": "string",
      "enum": [
        "FirstContact",
        "MessageSent",
        "ResponseReceived",
        "MeetingCall",
        "ProposalSent",
        "ProposalWon",
        "ProposalRejected",
        "FollowUpPending",
        "Note",
        "Discarded",
        "Reopened"
      ],
      "description": "Type of event"
    },
    "detail": {
      "type": "string",
      "default": "",
      "description": "Event notes",
      "example": "Sent proposal via email"
    },
    "occurredAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the event occurred",
      "example": "2024-01-01T00:00:00.000Z"
    }
  },
  "required": ["eventType", "occurredAt"],
  "x-readme-ref-name": "RegisterEventBody"
}
