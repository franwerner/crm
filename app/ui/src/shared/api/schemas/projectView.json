{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Project UUID",
      "example": "01938b0c-..."
    },
    "name": { "type": "string", "example": "Website Redesign" },
    "description": {
      "type": "string",
      "nullable": true,
      "example": "Full redesign of the corporate website"
    },
    "contactId": { "type": "string", "description": "Associated contact UUID" },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code",
      "example": "USD"
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Active", "Closed", "Cancelled"],
      "example": "Draft"
    },
    "startDate": {
      "type": "string",
      "description": "Start date (YYYY-MM-DD)",
      "example": "2025-01-01"
    },
    "originalPlannedEndDate": {
      "type": "string",
      "description": "Original planned end date before any extensions (YYYY-MM-DD)",
      "example": "2025-12-31"
    },
    "plannedEndDate": {
      "type": "string",
      "description": "Derived planned end date including all extensions (YYYY-MM-DD)",
      "example": "2026-01-14"
    },
    "createdBy": {
      "type": "string",
      "description": "User UUID who created this project"
    },
    "creator": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"],
      "description": "Creator user data. Present on detail endpoint."
    },
    "responsibles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "userName": { "type": "string", "nullable": true },
          "role": { "type": "string", "enum": ["Lead", "Member"] },
          "assignedBy": { "type": "string" },
          "assignedAt": { "type": "string" }
        },
        "required": [
          "id",
          "userId",
          "userName",
          "role",
          "assignedBy",
          "assignedAt"
        ]
      },
      "description": "Project responsibles"
    },
    "totals": {
      "type": "object",
      "properties": {
        "budget": {
          "type": "object",
          "properties": {
            "amountMinor": {
              "type": "number",
              "description": "Amount in minor currency units",
              "example": 150000
            },
            "currency": {
              "type": "string",
              "description": "ISO 4217 currency code",
              "example": "USD"
            }
          },
          "required": ["amountMinor", "currency"],
          "x-readme-ref-name": "Money"
        },
        "expenses": {
          "type": "object",
          "properties": {
            "amountMinor": {
              "type": "number",
              "description": "Amount in minor currency units",
              "example": 150000
            },
            "currency": {
              "type": "string",
              "description": "ISO 4217 currency code",
              "example": "USD"
            }
          },
          "required": ["amountMinor", "currency"],
          "x-readme-ref-name": "Money"
        },
        "profit": {
          "type": "object",
          "properties": {
            "amountMinor": {
              "type": "number",
              "description": "Signed amount in minor currency units (may be negative)",
              "example": -30000
            },
            "currency": {
              "type": "string",
              "description": "ISO 4217 currency code",
              "example": "USD"
            }
          },
          "required": ["amountMinor", "currency"],
          "x-readme-ref-name": "ProjectProfit"
        }
      },
      "required": ["budget", "expenses", "profit"],
      "description": "Derived financial totals"
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    }
  },
  "required": [
    "id",
    "name",
    "description",
    "contactId",
    "currency",
    "status",
    "startDate",
    "originalPlannedEndDate",
    "plannedEndDate",
    "createdBy",
    "responsibles",
    "totals",
    "createdAt",
    "updatedAt"
  ],
  "x-readme-ref-name": "ProjectView"
}
