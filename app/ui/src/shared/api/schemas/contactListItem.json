{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Contact UUID",
      "example": "01938b0c-..."
    },
    "name": { "type": "string", "example": "Jane Doe" },
    "contactType": {
      "type": "string",
      "enum": ["Person", "Company"],
      "example": "Person"
    },
    "sex": {
      "type": "string",
      "nullable": true,
      "enum": ["Male", "Female", "Other", "Unspecified", null],
      "example": "Female"
    },
    "notes": {
      "type": "string",
      "nullable": true,
      "example": "Met at trade show"
    },
    "pipelineState": {
      "type": "string",
      "enum": ["Contact", "Lead", "AtRisk", "Customer", "Discarded"],
      "example": "Contact"
    },
    "sourceChannel": {
      "type": "string",
      "nullable": true,
      "enum": ["Instagram", "WhatsApp", "Referral", "Email", "Other", null],
      "example": "Instagram"
    },
    "interestLevel": {
      "type": "string",
      "nullable": true,
      "enum": ["Cold", "Warm", "Hot", null],
      "example": "Warm"
    },
    "createdBy": {
      "type": "string",
      "description": "User UUID who created this contact"
    },
    "creator": {
      "type": "object",
      "nullable": true,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"],
      "description": "Creator user data. Null if the creator user no longer exists."
    },
    "primaryChannel": {
      "type": "object",
      "nullable": true,
      "properties": {
        "channelType": {
          "type": "string",
          "enum": [
            "Phone",
            "Email",
            "WhatsApp",
            "Instagram",
            "Website",
            "Other"
          ]
        },
        "value": { "type": "string" }
      },
      "required": ["channelType", "value"],
      "description": "Primary communication channel"
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-01T00:00:00.000Z"
    }
  },
  "required": [
    "id",
    "name",
    "contactType",
    "sex",
    "notes",
    "pipelineState",
    "sourceChannel",
    "interestLevel",
    "createdBy",
    "creator",
    "primaryChannel",
    "createdAt",
    "updatedAt"
  ],
  "x-readme-ref-name": "ContactListItem"
}
